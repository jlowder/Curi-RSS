{
  "appId": "com.jlowder.curi-rss",
  "productName": "Curi-RSS",
  "directories": {
    "output": "dist-electron"
  },
  "files": [
    "dist/**/*",
    "node_modules/**/*",
    "package.json"
  ],
  "extraMetadata": {
    "main": "dist/main.js"
  },
  "asarUnpack": [
    "dist/renderer/**/*",
    "dist/client/**/*"
  ],
  "mac": {
    "category": "public.app-category.news",
    "target": ["dmg", "zip"],
    "icon": "assets/icon.icns",
    "darkModeSupport": true
  },
  "win": {
    "target": ["nsis", "zip"],
    "icon": "assets/icon.ico"
  },
  "linux": {
    "target": ["AppImage"],
    "category": "Network",
    "icon": "assets/icon.png"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": true,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true
  },
  "dmg": {
    "background": "assets/dmg-background.png",
    "icon": "assets/icon.icns",
    "iconSize": 100,
    "contents": [
      {
        "x": 180,
        "y": 150,
        "type": "link",
        "path": "/Applications"
      },
      {
        "x": 130,
        "y": 150,
        "type": "file"
      }
    ]
  }
}
