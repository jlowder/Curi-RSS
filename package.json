{
  "name": "rest-express",
  "version": "1.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "NODE_ENV=development tsx server/index.ts",
    "build": "vite build && npm run build:server",
    "start": "NODE_ENV=production node dist/server.js",
    "check": "tsc",
    "test": "vitest",
    "test:e2e": "npx playwright test",
    "db:push": "drizzle-kit push",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build:main && npm run build:preload && npm run build:server && vite build && electron-builder",
    "electron:build:linux": "npm run build:main && npm run build:preload && npm run build:server && vite build && electron-builder --linux --x64",
    "electron:build:mac": "npm run build:main && npm run build:preload && npm run build:server && vite build && electron-builder --mac",
    "electron:build:win": "npm run build:main && npm run build:preload && npm run build:server && vite build && electron-builder --win",
    "electron:watch": "tsc --watch",
    "electron:preload": "tsc -p src/preload/tsconfig.json",
    "build:main": "tsc -p tsconfig.main.json && cp dist/index.js dist/main.js",
    "build:server": "esbuild server/index.ts --platform=node --bundle --format=cjs --outfile=dist/server.js --external:better-sqlite3 --external:keytar --external:puppeteer --external:pdf-lib --external:esbuild --external:electron",
    "build:preload": "tsc -p tsconfig.preload.json"
  },
